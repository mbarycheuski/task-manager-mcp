{
  "permissions": {
    "allow": [
      "Bash(git commit *)",
      "Bash(git add *)",
      "Bash(dotnet --version)",
      "Bash(dotnet new *)",
      "Bash(dotnet package *)",
      "Bash(dotnet *)",
      "Bash(docker compose *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/csharpier-format.sh\"",
            "statusMessage": "Formatting with CSharpier..."
          }
        ]
      }
    ]
  }
}
