{
  "permissions": {
    "allow": [
      "Bash(git commit *)",
      "Bash(git add *)",
      "Bash(dotnet --version)",
      "Bash(dotnet new *)",
      "Bash(dotnet package *)",
      "Bash(dotnet *)",
      "Bash(docker compose *)",
      "mcp__task-manager__get_all_tasks",
      "mcp__task-manager__add_task"
    ]
  },
  "enabledMcpjsonServers": [
    "task-manager"
  ],
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "grep -q '\"file_path\":\"[^\"]*\\.env\"' <<< \"$(cat)\" && echo '{\"continue\": false, \"stopReason\": \"Cannot read .env file\"}' || true",
            "statusMessage": "Checking for .env file..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "if": "Edit(*.cs)",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/csharpier-format.sh\"",
            "statusMessage": "Formatting with CSharpier..."
          },
          {
            "type": "command",
            "if": "Write(*.cs)",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/csharpier-format.sh\"",
            "statusMessage": "Formatting with CSharpier..."
          }
        ]
      }
    ]
  }
}
